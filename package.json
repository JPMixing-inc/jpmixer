{
  "name": "jpmixer",
  "version": "1.0.0-beta.1",
  "description": "JPMixer — browser-based monitor mix control for DiGiCo consoles",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.jpmixing.oscmixer",
    "productName": "JPMixer",
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!assets/icon.iconset",
      "!assets/trayTemplateFinal.png",
      "!assets/DMG background.png",
      "!assets/DMG Icon and App Icon.png"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "dmg": {
      "title": "JPMixer ${version}",
      "icon": "assets/icon.icns",
      "background": "assets/dmg-background.png",
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 200,
          "type": "file"
        },
        {
          "x": 480,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "osc": "^2.4.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  }
}
